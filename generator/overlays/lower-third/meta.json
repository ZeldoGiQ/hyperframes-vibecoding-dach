{
  "id": "lower-third",
  "name": "Lower Third",
  "type": "overlay",
  "duration": 4,
  "aspectRatio": "16:9",
  "transparent": true,
  "description": "Speaker name + title/role, slides in from the left. Bottom-left position, accent bar.",
  "variables": [
    {
      "key": "NAME",
      "label": "Speaker name",
      "type": "string",
      "required": true,
      "maxLength": 30,
      "example": "Hannes Müller"
    },
    {
      "key": "TITLE",
      "label": "Title or role",
      "type": "string",
      "required": false,
      "maxLength": 50,
      "example": "Founder, AIVC DACH"
    }
  ],
  "styleVars": [
    { "key": "--primary-color", "label": "Accent bar color", "type": "color", "default": "#00FF94" },
    { "key": "--text-color", "label": "Text color", "type": "color", "default": "#FFFFFF" },
    { "key": "--bg-color", "label": "Background color", "type": "color", "default": "rgba(10,10,10,0.85)" },
    { "key": "--font-size-name", "label": "Name font size (px)", "type": "number", "default": 56 },
    { "key": "--font-size-title", "label": "Title font size (px)", "type": "number", "default": 28 },
    { "key": "--animation-duration", "label": "Slide-in duration (s)", "type": "number", "default": 0.4 }
  ]
}
