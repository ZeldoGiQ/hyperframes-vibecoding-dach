# Environment variables example
# Copy this file to .env.local and update the values as needed

# Node
NODE_ENV=development

# Public
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_MARBLE_API_URL=https://api.marblecms.com

# Server
DATABASE_URL="postgresql://opencut:opencut@localhost:5432/opencut"
BETTER_AUTH_SECRET=your_better_auth_secret

UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=example_token

MARBLE_WORKSPACE_KEY=your_workspace_key_here

FREESOUND_CLIENT_ID=your_client_id_here
FREESOUND_API_KEY=your_api_key_here

# --- AIVC DACH AI layer (alpha.2) ---
# Pick one provider. Anthropic is the default if AIVC_AI_PROVIDER is unset.
# Allowed values: anthropic | google | openai | ollama
AIVC_AI_PROVIDER=anthropic

# Model selection is per-provider and required (no hardcoded defaults — provider
# model lineups change too quickly for that to age well). Pick the model id
# from your provider's current model list and paste it below. Linked URLs for
# each provider are next to the corresponding *_API_KEY entry.

# Anthropic — get a key at https://console.anthropic.com/settings/keys
# Pick a current model from https://docs.anthropic.com/en/docs/about-claude/models
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Google (Gemini) — get a key at https://aistudio.google.com/app/apikey
# Pick a current model from https://ai.google.dev/gemini-api/docs/models
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=

# OpenAI — get a key at https://platform.openai.com/api-keys
# Pick a current model from https://platform.openai.com/docs/models
OPENAI_API_KEY=
OPENAI_MODEL=

# Ollama — local server. Default points at the standard Ollama install.
# Pick a model from https://ollama.com/library and pull it locally first
# (e.g. `ollama pull llama3.2`). Then put the same id in OLLAMA_MODEL.
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_MODEL=
