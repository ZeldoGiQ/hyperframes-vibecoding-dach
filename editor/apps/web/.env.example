# Environment variables example
# Copy this file to .env.local and update the values as needed

# Node
NODE_ENV=development

# Public
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_MARBLE_API_URL=https://api.marblecms.com

# Server
DATABASE_URL="postgresql://opencut:opencut@localhost:5432/opencut"
BETTER_AUTH_SECRET=your_better_auth_secret

UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=example_token

MARBLE_WORKSPACE_KEY=your_workspace_key_here

FREESOUND_CLIENT_ID=your_client_id_here
FREESOUND_API_KEY=your_api_key_here

# --- AIVC DACH AI layer (alpha.2) ---
# Pick one provider. Anthropic is the default if AIVC_AI_PROVIDER is unset.
# Allowed values: anthropic | openai | ollama
AIVC_AI_PROVIDER=anthropic

# Optional model override. Sensible defaults are used if blank:
#   anthropic -> claude-sonnet-4-5
#   openai    -> gpt-4o-mini
#   ollama    -> llama3.2
AIVC_AI_MODEL=

# Anthropic — get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI — get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Ollama — local server. Default points at the standard Ollama install.
OLLAMA_BASE_URL=http://localhost:11434/api
