{
  "id": "vertical-short",
  "name": "Vertical Short",
  "duration": 15,
  "aspectRatio": "9:16",
  "resolution": "1080x1920",
  "description": "Vertical short format for TikTok, Instagram Reels and YouTube Shorts",
  "scenes": [
    {"id": 1, "from": 0, "to": 2, "name": "Hook", "description": "Big hook text"},
    {"id": 2, "from": 2, "to": 12, "name": "Content", "description": "4 content lines, one after the other"},
    {"id": 3, "from": 12, "to": 15, "name": "CTA", "description": "Call-to-action with platform hint"}
  ],
  "variables": [
    {"key": "HOOK", "label": "Hook word/phrase (short!)", "required": true, "example": "STOP!", "maxLength": 15},
    {"key": "CONTENT_LINE_1", "label": "Content line 1", "required": true, "example": "You're doing it wrong", "maxLength": 40},
    {"key": "CONTENT_LINE_2", "label": "Content line 2", "required": true, "example": "Try this instead", "maxLength": 40},
    {"key": "CONTENT_LINE_3", "label": "Content line 3", "required": true, "example": "It only takes 5 minutes", "maxLength": 40},
    {"key": "CONTENT_LINE_4", "label": "Content line 4", "required": true, "example": "Thank me later", "maxLength": 40},
    {"key": "CTA", "label": "Call-to-action", "required": true, "example": "More tips", "maxLength": 30},
    {"key": "PLATFORM", "label": "Platform for the CTA", "required": true, "example": "TikTok", "maxLength": 20}
  ]
}
